###############################################################################
#  AutoMailDeploy — Single-file configuration
#  Copy this file to .env and fill in every value before running install.sh
###############################################################################

# ── Domain & Hostname ────────────────────────────────────────────────────────
# Primary mail domain (the part after @ in email addresses)
MAIL_DOMAIN=example.com

# FQDN of the mail server (the hostname that MX records point to)
MAIL_HOSTNAME=mail.example.com

# Server's public IPv4 address (used for DNS record output)
SERVER_IP=203.0.113.10

# ── Let's Encrypt / SSL ─────────────────────────────────────────────────────
# Email address for Let's Encrypt notifications (must be a REAL email for production).
# For local testing (.local/.test domains), this is ignored — self-signed certs are auto-generated.
LETSENCRYPT_EMAIL=admin@example.com

# Set to "true" to use Let's Encrypt staging servers (for testing with a real domain)
LETSENCRYPT_STAGING=false

# ── Admin Mailbox ────────────────────────────────────────────────────────────
# Default admin mailbox (created automatically during install)
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeMe_StrongPassword123!

# ── Additional Mailboxes ────────────────────────────────────────────────────
# Comma-separated list of additional users to create: user1:password1,user2:password2
# Leave empty to only create the admin mailbox
EXTRA_USERS=

# ── Database Credentials (Roundcube) ─────────────────────────────────────────
MYSQL_ROOT_PASSWORD=RootDbP@ssw0rd_Change!
MYSQL_DATABASE=roundcubemail
MYSQL_USER=roundcube
MYSQL_PASSWORD=RoundcubeDbP@ss_Change!

# ── Rspamd ───────────────────────────────────────────────────────────────────
# Password for the Rspamd web UI (will be hashed automatically)
RSPAMD_PASSWORD=RspamdWebUI_P@ss_Change!

# ── Roundcube ────────────────────────────────────────────────────────────────
# Random 24-char DES key for Roundcube (generate with: openssl rand -hex 12)
ROUNDCUBE_DES_KEY=change_this_to_a_random_24char

# ── Docker Network ───────────────────────────────────────────────────────────
# Subnet for the internal mail network (usually no need to change)
DOCKER_SUBNET=172.28.0.0/16

# ── Timezone ─────────────────────────────────────────────────────────────────
TZ=UTC

# ── Backup Configuration ─────────────────────────────────────────────────────
# Number of days to keep local backups (older backups are auto-deleted)
BACKUP_RETENTION_DAYS=30

# Optional: rsync target for remote backups (e.g. user@backup-server:/backups/)
# Leave empty to only keep local backups in ./backups/
BACKUP_REMOTE=

# ── Monitoring & Alerts ──────────────────────────────────────────────────────
# Email address for health alerts (default: admin mailbox)
# Set to an external address to receive alerts even if the mail server is down
MONITOR_ALERT_EMAIL=
